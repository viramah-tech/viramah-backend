PORT=5000
MONGODB_URI=mongodb://localhost:27017/viramah
JWT_SECRET=viramah-dev-secret-key-change-in-production
JWT_EXPIRE=7d
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
MAX_FILE_SIZE=10485760

# AWS S3 Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=viramah-uploads
# Optional: CloudFront domain for faster file delivery
# AWS_CLOUDFRONT_DOMAIN=d1234abcdef.cloudfront.net
